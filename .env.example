# 🤖 石門小智鈴環境變數範本 (Vite 版)

# Google Gemini API Key
# 取得網址: https://aistudio.google.com/
# 注意：在 Vite 中，前端變數必須以 VITE_ 開頭才會暴露給瀏覽器
VITE_GEMINI_API_KEY=你的_GEMINI_API_金鑰

# Firebase 配置 (用於 Firestore 資料庫)
VITE_FIREBASE_API_KEY=你的_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=你的_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=你的_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=你的_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=你的_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=你的_APP_ID

# LINE Messaging API (重要說明)
# ---------------------------------------------------------
# 注意：由於目前改為「純前端 (Vite)」架構並部署於 GitHub Pages，
# 瀏覽器端因 CORS 限制與安全性考量，無法直接呼叫 LINE API。
# 若需恢復 LINE 通知，建議將以下變數設定於 Firebase Functions 或其他後端。
# ---------------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=你的_LINE_頻道轉接金鑰
LINE_USER_ID=你的_LINE_使用者識別碼
