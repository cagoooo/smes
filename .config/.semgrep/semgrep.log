2025-07-08 04:36:36,579 - semgrep.rule_match - DEBUG - match_key = ('\n    $(document).on(\'click\', \'.btn-outline-secondary\', function() {\n      // 获取与按钮相关联的消息元素\n      let messageElement = $(this).closest(\'.list-group-item-action\').find(\'p.mb-0\');\n\n      // 创建一个临时的textarea元素来复制文本\n      let tempTextarea = $("<textarea>");\n      $("body").append(tempTextarea);\n      tempTextarea.val(extractPlainTextUrls(messageElement.html())).select();\n      document.execCommand("copy");\n      tempTextarea.remove();\n\n      // 显示模态框，而不是标准的alert\n      $(\'#copyModal\').modal(\'show\');\n    });\n\n    // 函数：从HTML中提取纯文本链接，同时保留换行\n    function extractPlainTextUrls(htmlContent) {\n      let tempDiv = document.createElement("div");\n      tempDiv.innerHTML = htmlContent;\n\n      // 处理换行符\n      Array.from(tempDiv.getElementsByTagName("BR")).forEach(br => {\n          br.replaceWith("\\n");\n      });\n      Array.from(tempDiv.getElementsByTagName("P")).forEach(p => {\n          p.innerText += "\\n";\n      });\n\n      // 将超链接转换为纯文本URL\n      Array.from(tempDiv.querySelectorAll("a")).forEach(a => {\n          a.replaceWith(a.href);\n      });\n\n      return tempDiv.innerText.trim();\n    }\n\n    // 函数：将HTML内容转换为纯文本，保留必要的格式（如换行）\n    function convertHtmlToText(htmlElement) {\n      return htmlElement.html().replace(/<br\\s*[\\/]?>/gi, \'\\n\').replace(/<\\/?p>/gi, \'\\n\').trim();\n    }\n    \n    $(document).ready(function() {\n      // ... 其他jQuery代碼 ...\n    function scrollToBottom() {\n        var chatContainer = $("#list-group");\n        chatContainer.scrollTop(chatContainer[0].scrollHeight);\n      }\n\n      // 每次添加新消息後調用\n      scrollToBottom();\n    });\n\n    // 函數：將文本中的網址轉換為超連結\n    function convertUrlsToLinks(text) {\n      // 更新後的正則表達式\n      const urlRegex = /(\\bhttps?:\\/\\/[-A-Z0-9+&@#/%?=~_|!:,.;]*[-A-Z0-9+&@#/%=~_|])/ig;\n      return text.replace(urlRegex, function(url) {\n        return \'<a href="\' + url + \'" target="_blank" style="color: blue;">\' + url + \'</a>\';\n      });\n    }\n    \n    $("#user-input").on("input", function () {\n      this.style.height = "auto";\n      this.style.height = this.scrollHeight + "px";\n    });\n\n    function sendEmailNotification(userQuestion, aiAnswer) {\n      $.ajax({\n        type: "POST",\n        url: "/send_email_notification",\n        contentType: "application/json",\n        data: JSON.stringify({\n          \'user_question\': userQuestion,\n          \'ai_answer\': aiAnswer\n        }),\n        success: function (data) {\n          console.log(data);\n        },\n        error: function (error) {\n          console.error(error);\n        }\n      });\n    }\n\n    function saveConversationToBackend(userQuestion, aiAnswer) {\n      // 獲取當前時間\n      const timestamp = new Date().toISOString();\n\n      $.ajax({\n        type: "POST",\n        url: "/save_conversation",\n        contentType: "application/json",\n        data: JSON.stringify({\n          \'user_question\': userQuestion,\n          \'ai_answer\': aiAnswer,\n          \'timestamp\': timestamp // 將時間戳記添加到儲存的資料中\n        }),\n        success: function (data) {\n          console.log(data);\n        },\n        error: function (error) {\n          console.error(error);\n        }\n      });\n    }\n\n    function formatTextForClipboard(text) {\n      return text.replace(/<br>/g, \'\\n\');\n    }\n\n    function copyToClipboard(html) {\n      // 创建一个临时的DIV来插入HTML内容\n      let tmpDiv = document.createElement("DIV");\n      tmpDiv.innerHTML = html;\n\n      // 递归处理节点，将HTML转换为纯文本\n      function processNode(node) {\n        let text = "";\n        if (node.nodeType === Node.TEXT_NODE) {\n          text = node.nodeValue;\n        } else if (node.nodeType === Node.ELEMENT_NODE) {\n          for (let child of node.childNodes) {\n            text += processNode(child);\n          }\n          if (node.tagName === "P" || node.tagName === "DIV") {\n            text += \'\\n\'; // 段落和DIV元素后添加换行符\n          } else if (node.tagName === "BR") {\n            text += \'\\n\'; // <br>元素添加换行符\n          } else if (node.tagName === "LI") {\n            text = \'* \' + text.trim() + \'\\n\'; // 列表项前添加\'*\'和换行符\n          }\n        }\n        return text;\n      }\n\n      let textToCopy = processNode(tmpDiv).trim(); // 移除首尾多余的空白字符\n\n      // 创建一个textarea元素来选中并复制文本\n      let el = document.createElement(\'textarea\');\n      el.value = textToCopy;\n      document.body.appendChild(el);\n      el.select();\n      document.execCommand(\'copy\');\n      document.body.removeChild(el);\n    }\n\n    function sendQuestion() {\n      let inputQuestion = $("#user-input").val();\n      $("#user-input").val("");\n      $("#user-input").css("height", "");  // 新增這行來將輸入框的大小恢復到原來的大小\n\n      let appendConversation = "";\n      appendConversation += `\n      <a href="#" class="list-group-item list-group-item-action d-flex gap-3 py-3">\n          <img src="https://www.smes.tyc.edu.tw/uploads/tadnews/image/logo/logo.png" alt="" width="64" height="64" class="rounded-circle flex-shrink-0">\n          <div class="d-flex gap-2 w-100 justify-content-between">\n            <div>\n              <p class="mb-0 opacity-75" style="font-weight: bold; color: blue;">${inputQuestion}</p>\n            </div>\n            <div class="mt-1 small">\n              <button class="btn btn-outline-secondary btn-sm" style="background-color: #90ee90; color: black; font-weight: bold;">複製</button>\n            </div>\n          </div>\n        </a>`;\n\n      $("#list-group").prepend(appendConversation);\n\n      // Create a unique ID\n      let ai_reply_id = \'ai-reply-\' + Date.now();\n\n      // Insert a placeholder response with "請稍待..."\n      let placeholderResponse = `<a id="${ai_reply_id}" href="#" class="list-group-item list-group-item-action d-flex gap-3 py-3 answer-background">\n        <img src="https://www.smes.tyc.edu.tw/uploads/tadnews/image/person/k-a.png" alt="" width="64" height="66" class="rounded-circle flex-shrink-0">\n        <div class="d-flex gap-2 w-100 justify-content-between">\n          <div>\n            <p class="mb-0 opacity-75 blink green-text" style="font-weight: bold;">思考回答中(字數多時需等待)</p>\n            <div class="mt-1 small">\n              <button class="btn btn-outline-secondary btn-sm" style="background-color: #ffff99; color: black; font-weight: bold;">複製</button>\n            </div>\n          </div>\n        </div>\n      </a>`;\n\n      $("#list-group").prepend(placeholderResponse);\n\n      $.ajax({\n        type: "POST",\n        url: "/",\n        data: {\'prompt\': inputQuestion},\n        success: function (data) {\n          // Replace placeholder text with the actual answer\n          let ai_answer = data.ai_answer.replace(/\\n/g, \'<br>\'); // 将换行符转换为HTML换行\n          console.log(ai_answer); // 打印轉換後的答案\n          ai_answer = convertUrlsToLinks(ai_answer); // 將網址轉換為超連結\n          let ai_answer_chars = ai_answer.split(\'\');\n          let current_ai_answer = "";\n\n          // Separate the paragraph and button elements\n          let paragraph = $(`#${ai_reply_id} p`);\n          let button = $(`#${ai_reply_id} button`);\n\n          paragraph.html("");  // clear the placeholder text\n          button.on(\'click\', function() {\n            copyToClipboard(current_ai_answer);\n          });\n\n          // 每15毫秒添加一个字符到对话框\n          let intervalId = setInterval(function() {\n            if (ai_answer_chars.length > 0) {\n              // 将下一个字符添加到当前的AI回答\n              current_ai_answer += ai_answer_chars.shift();\n\n              // 更新对话框的内容\n              paragraph.html(current_ai_answer);\n            } else {\n              // 如果所有字符都已经添加到对话框，则停止setInterval()函数\n              clearInterval(intervalId);\n\n              // 移除 \'blink\' 和 \'green-text\' CSS classes\n              paragraph.removeClass("blink green-text");\n\n              // 添加 \'black-text\' CSS class\n              paragraph.addClass("black-text");\n            